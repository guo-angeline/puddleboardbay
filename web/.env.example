# PostHog analytics. Copy to .env.local and fill in your project key.
# Leave unset to disable analytics (the app runs fine without it).
# Find the key under PostHog → Settings → Project → Project API Key.
NEXT_PUBLIC_POSTHOG_KEY=
# US cloud: https://us.i.posthog.com  |  EU cloud: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Supabase (server-only; used by /api/alerts/subscribe)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cron auth (server-only; Vercel Cron sends it as Authorization: Bearer <value>)
CRON_SECRET=
